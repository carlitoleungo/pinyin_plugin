{
  "manifest_version": 2,
  "name": "PinyinOverlay",
  "version": "0.1.0",
  "description": "Overlays pinyin pronunciation above Chinese characters on webpages.",

  "browser_specific_settings": {
    "gecko": {
      "id": "pinyin-overlay@localhost",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "PinyinOverlay"
  },

  "permissions": ["storage"],

  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "css": ["content_scripts/content.css"],
      "js": ["vendor/pinyin-pro.js", "content_scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}
