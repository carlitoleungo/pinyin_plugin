{
  "manifest_version": 2,
  "name": "PinyinOverlay",
  "version": "0.1.0",
  "description": "Overlays pinyin pronunciation above Chinese characters on webpages.",

  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "css": ["content_scripts/content.css"],
      "js": ["vendor/pinyin-pro.js", "content_scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}
