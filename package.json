{
  "name": "pinyin-overlay",
  "version": "0.1.0",
  "description": "Firefox extension: pinyin overlay for Chinese characters",
  "private": true,
  "scripts": {
    "build": "mkdir -p vendor && esbuild node_modules/pinyin-pro/dist/index.js --bundle --global-name=pinyinPro --outfile=vendor/pinyin-pro.js --platform=browser",
    "dev": "npm run build && web-ext run"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "web-ext": "^8.0.0"
  },
  "dependencies": {
    "pinyin-pro": "^3.28.0"
  }
}
